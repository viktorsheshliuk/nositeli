{{header}}{{column_left}}
<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<div class="pull-right">
				<a onclick="$('#form input[name=apply]').val(1); $('#form').submit();" data-toggle="tooltip" title="{{button_apply}}" class="btn btn-success"><i class="fa fa-check"></i></a>
				<button type="submit" form="form" data-toggle="tooltip" title="{{button_save}}" class="btn btn-primary"><i class="fa fa-save"></i></button>
				<a href="{{cancel}}" data-toggle="tooltip" title="{{button_cancel}}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
				<h1>{{heading_title}}</h1>
				<ul class="breadcrumb">
					{% for breadcrumb in breadcrumbs %}
						<li><a href="{{breadcrumb.href}}">{{breadcrumb.text}}</a></li>
					{% endfor %}
				</ul>
			</div>
		</div>
	<div class="container-fluid">
		{% if success %}
			<div class="alert alert-success"><i class="fa fa-check-circle"></i>{{success}}</div>
		{% endif %}
		{% if error_warning %}
			<div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i>{{error_warning}}</div>
		{% endif %}
		<div class="panel panel-default"> 
			<div class="panel-heading"><h3 class="panel-title"><i class="fa fa-pencil"></i> Настройки модуля</h3></div>
			<div class="tab-pane">
				<form action="{{action}}" method="post" enctype="multipart/form-data" name="setting" id="form">
					<table id="module" class="list">
						<tr>
							<td>{{text_addtocart_logic}}</td>
							<td>
								<input type="checkbox" name="popupcart[addtocart_logic]" value="1" 
								{% if settings.addtocart_logic %} 
								checked="checked" 
								{% endif %}
								/> &nbsp; Если не отмечено, то просто будет меняться надпись на кнопке
							</td>
						</tr>
						<tr>
							<td>{{text_click_on_cart}}</td>
							<td>
								<input type="checkbox" name="popupcart[click_on_cart]" value="1" 
								{% if settings.click_on_cart %} 
								checked="checked" 
								{% endif %}
								/> &nbsp; Если не отмечено, то просто будет стандартный блок корзины
							</td>
						</tr>
						<tr>
							<td>{{text_related_show}}</td>
							<td><input type="checkbox" name="popupcart[related_show]" value="1" 
							    {% if settings.related_show %} 
								checked="checked" 
								{% endif %}
								/>
							</td>
						</tr>
						<tr>
							<td>{{text_related_heading}}</td>
							<td>
								{% for language in languages %}
									<div class="input-group">          
										<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{language.name}}" /></span>
										<input type="text" name="popupcart[related_heading][{{language.language_id}}]" value="{% set lan = language.language_id|number_format %}{% set sett
										 = settings.related_heading %}{% if sett[lan] %}{{ sett[lan] }}{% else %}{{entry_related_heading}}{% endif %}" class="form-control" />
									</div>
								{% endfor %}
							</td>
						</tr>
						<tr>
							<td>{{text_related_product}}</td>
							<td>
								<label><input type="checkbox" name="popupcart[related_product1]" value="1" {% if settings.related_product1%} checked="checked" {% endif %} /><span></span>{{text_related_product0}}</label><br />
								<label><input type="checkbox" name="popupcart[related_product2]" value="1" {% if settings.related_product2 %} checked="checked" {% endif %} /><span></span>{{text_related_product1}}</label><br />
							</td>
						</tr>
						<tr>
							<td>{{text_head}}</td>
							<td>
								{% for language in languages %}
									<div class="input-group">
										<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{language.name}}" /></span>
										<input type="text" name="popupcart[module_head][{{language.language_id}}]" value="{% set lan = language.language_id %}{% set sett = settings.module_head%}{% if sett[lan] %}{{sett[lan]}}{% else %}{{entry_head}}{% endif %}" class="form-control" />
									</div>
								{% endfor %}		
							</td>
						</tr>
						<tr>
							<td>{{text_button_name_shopping_show}}</td>
							<td>
								<label><input type="checkbox" name="popupcart[button_shopping_show]" value="1" 
									{% if settings.button_shopping_show %}
									checked="checked"
									{% endif %} 
									/><span></span></label>
							</td>
						</tr>
						<tr>
							<td>{{text_button_name_shopping}}</td>
							<td>
								{% for language in languages %}
									<div class="input-group">
										<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{language.name}}" /></span>
										<input type="text" name="popupcart[button_shopping][{{language.language_id}}]" value="{% set lan = language.language_id %}{% set sett = settings.button_shopping %}{% if sett[lan] %}{{sett[lan]}}{% else %}{{entry_button_name_shopping}}{% endif %}" class="form-control" />
									</div>
								{% endfor %}
							</td>
						</tr>
						<tr>
							<td>{{text_button_name_cart_show}}</td>
							<td>
								<label><input type="checkbox"  name="popupcart[button_cart_show]" value="1"
								 {% if settings.button_cart_show %} 
								 checked="checked"
								 {% endif %} 
								 /><span></span></label>
							</td>
						</tr>
						<tr>
							<td>{{text_button_name_cart}}</td>
							<td>
								{% for language in languages %}
									<div class="input-group">
										<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{language.name}}" /></span>
										<input type="text" name="popupcart[button_cart][{{language.language_id}}]" value="{% set lan = language.language_id %}{% set sett = settings.button_cart %}{% if sett[lan] %}{{sett[lan]}}{% else %}{{entry_button_name_cart}}{% endif %}" class="form-control"/>
									</div>
								{% endfor %}	
							</td>
						</tr>
						<tr>
							<td>{{text_button_name_checkout}}</td>
							<td>
								{% for language in languages %}
									<div class="input-group">
										<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{language.name}}" /></span>	
										<input type="text" name="popupcart[button_checkout][{{language.language_id}}]" value="{% set lan = language.language_id %}{% set sett = settings.button_checkout %}{% if sett[lan] %}{{sett[lan]}}{% else %}{{entry_button_name_checkout}}{% endif %}" class="form-control" />
									</div>
								{% endfor %}	
							</td>
						</tr>
						<tr>
							<td>{{text_manufacturer_show}}</td>
							<td>
								<label><input type="checkbox"  name="popupcart[manufacturer_show]" value="1" 

									{% if settings.manufacturer_show %}
									 checked="checked"
									{% endif %}
									 /><span></span></label>
							</td>
						</tr>
						<tr>
							<td>{{text_button_name_incart_logic}}</td>
							<td>
								<label><input type="radio" id="logic0" name="popupcart[button_incart_logic]" value="0" 
								{% if settings.button_incart_logic or settings.button_incart_logic == 0 %} 
								checked="checked"
								{% endif %}
								/><span></span>{{text_button_name_incart_logic_label0}}</label><br />
								<label><input type="radio" id="logic1" name="popupcart[button_incart_logic]" value="1" 
								{% if settings.button_incart_logic and settings.button_incart_logic == 1 %}
								checked="checked"
								{% endif %}
								/><span></span>{{text_button_name_incart_logic_label1}}</label>
							</td>
						</tr>
						<tr>
							<td>{{text_button_name_incart}}</td>
							<td>
								{% for language in languages %}
									<div class="input-group">
										<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{language.name}}" /></span>
										<input type="text" name="popupcart[button_incart][{{language.language_id}}]" value="{% set lan = language.language_id %}{% set sett = settings.button_incart %}{% if sett[lan] %}{{set[lan]}}{% else %}{{entry_button_name_incart}}{% endif %}" class="form-control" />
									</div>
								{% endfor %}
							</td>
						</tr>
						<tr>
							<td>{{text_button_name_incart_with_options}}</td>
							<td>
								{% for language in languages %}
									<div class="input-group">
										<span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{language.name}}" /></span>
										<input type="text" name="popupcart[button_incart_with_options][{{language.language_id}}]" value="{% set lan = language.language_id %}{% set sett = settings.button_incart_with_options %}{% if sett[lan] %}{{sett[lan]}}{% else %}{{entry_button_name_incart_with_options}}{% endif %}" class="form-control" />
									</div>
								{% endfor %}
							</td>
						</tr>
						<tr>
							<td colspan="2"><div id="copyright">{{text_copyright}}</div></td>
						</tr>
					</table>	
					<input type="hidden" name="apply" value="0" />
				</form>
			</div>
		</div>
	</div>
</div>
<style> 
	h1 {display:block !important;}
	#module {width:100%;}
	#module tr:nth-child(even) {background:#f5f5f5;border-top:solid 1px #ddd;border-bottom:solid 1px #ddd;}
	#module tr td:first-child{width:350px; border-right:solid 1px #ddd;}
	#module tr td {padding:10px}
	#module a{cursor:pointer;}
	#copyright {padding:15px;font-size:1.1em;}
	#copyright a {color:#f00;text-decoration:underline}
	.odd {background:#f4f4f4 !important;}
	.scrollbox {border:1px solid #CCCCCC; width: 350px; height: 150px; padding:4px 6px; margin-bottom:10px; background: #FFFFFF; overflow-y: scroll;}
  </style>
{{footer}}