              <!-- 1. Главный слайдер -->
              <div class="fn_images_main swiper">
                <div class="swiper-wrapper">
                  
                  <!-- Главное (основное) фото -->
                  {% if thumb %}
                    <a class="images_link swiper-slide" href="{{ popup }}" data-fancybox="group" title="{{ heading_title }}" data-caption="{{ heading_title }} #1">
                      <img class="fn_image" src="{{ thumb }}" title="{{ heading_title }}" alt="{{ heading_title }}" />
                    </a>
                  {% endif %}
                  
                  <!-- Дополнительные фото -->
                  {% if images %}
                    {% for image in images %}
                      <a class="images_link swiper-slide" href="{{ image.popup }}" data-fancybox="group" data-caption="{{ heading_title }} #{{ loop.index + 1 }}" title="{{ heading_title }}">
                        <img src="{{ image.thumb }}" title="{{ heading_title }}" alt="{{ heading_title }}" />
                      </a>
                    {% endfor %}
                  {% endif %}
                  
                </div>
                <span class="swiper-notification" aria-live="assertive" aria-atomic="true"></span>
