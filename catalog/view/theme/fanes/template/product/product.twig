          radio[i].onchange = checkRadio;
        }
      }

    function checkRadio(){
      var add_thumbs = document.querySelectorAll('.image-additional .thumbnail');
      $('.thumbnails li a').removeClass('selected');
      for(i = 0; i<radio.length; i++){
