<script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [{
       {% for key, breadcrumb in breadcrumbs %}
            {% if key + 1 < breadcrumbs|length %}
                "@type": "ListItem",
        "position": {{ loop.index }},  
          {% if loop.index == 1 %} "name" : "Главная" {% else %} "name": " {{ breadcrumb.text }} " {% endif %} ,
                 "item": "{{ breadcrumb.href }}"
             },{  
          {% else %}
                 "@type": "ListItem",
        "position": {{ loop.index }},  
           "name": " {{ breadcrumb.text }} ",
                 "item": "{{ breadcrumb.href }}"
                }]          
            {% endif %}
     {% endfor %}
    }
</script>
