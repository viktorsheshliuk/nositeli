<style>
.category-wall {
	display: -webkit-box;
	display: -ms-flexbox;
	display: flex;
	-webkit-box-orient: horizontal;
	-webkit-box-direction: normal;
	-ms-flex-flow: row wrap;
	flex-flow: row wrap;
	margin: 0 0 45px 0;
	margin-left: -5px;
	margin-right: -5px;
}

.category-wall__item {
	display: block;
	width: 50%;
	height: 250px;
	position: relative;
	padding: 5px;
}

@media (min-width: 900px) {
	.category-wall .category-wall__item:nth-child(6n+2),
	.category-wall .category-wall__item:nth-child(6n+3),
	.category-wall .category-wall__item:nth-child(6n+4),
	.category-wall .category-wall__item:nth-child(6n+6) {
		width: 25%;
	}
}

.category-wall a {
	overflow: hidden;
	position: relative;
	display: block;
	height: 100%;
	width: 100%;
}

.category-wall a,
.category-wall a:visited {
	color: #4caf50;
	text-decoration: none;
}

.category-wall .category-wall__item .category-wall__image {
	background-repeat: no-repeat;
	background-position: center;
	background-size: cover;
	display: block;
	transition: .3s;
	width: 100%;
	height: 100%;
	-webkit-transform: scale(1);
	transform: scale(1);
}

.category-wall .category-wall__item .category-wall__text {
	font-weight: 500;
	font-size: 18px;
	padding: 15px 30px;
	position: absolute;
	left: 0;
	bottom: 0;
}

.category-wall a:active .category-wall__image,
.category-wall a:hover .category-wall__image {
	-webkit-transform: scale(1.05);
	transform: scale(1.05);
}

@media (max-width: 600px) {
	.category-wall .category-wall__item {
		height: 180px;
		width: 100%;
	}
}
</style>
<h3>{{ heading_title }}</h3>
<div class="category-wall">  
  {% for category in categories %}
  <div class="category-wall__item">
    <a class="category-wall__link" href="{{ category.href }}">
    <span class="category-wall__image" style="background-image: url('{{ category.image }}'); background-size: auto; border: 1px solid black;"></span>
    <span class="category-wall__text">{{ category.name }}</span>
    </a>
  </div>
  {% endfor %}
</div>